# ─── Supabase ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
# "Publishable key" is Supabase's current name for the safe client-side key
# (previously called "anon key" — same key, new label in their dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# ─── News / Intel Fetching (optional, for richer auto-fetch) ─────────────────
# SerpAPI lets us search Google News for Clockwork mentions
# Get a free key at: https://serpapi.com (100 searches/month free)
SERP_API_KEY=

# ─── App Config ───────────────────────────────────────────────────────────────
# Your name, shown in the header
NEXT_PUBLIC_USER_NAME=Doug
